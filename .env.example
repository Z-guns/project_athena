ATHENA_APP_NAME=Project Athena
ATHENA_ENVIRONMENT=development
ATHENA_DEBUG=false
ATHENA_LOG_LEVEL=INFO
ATHENA_API_V1_PREFIX=/api/v1
ATHENA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/athena

ATHENA_REDIS_URL=redis://localhost:6379/0

ATHENA_SECRET_KEY=replace-with-a-secure-random-value
ATHENA_JWT_ALGORITHM=HS256
ATHENA_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

ATHENA_OPENAI_API_KEY=
ATHENA_GEMINI_API_KEY=
ATHENA_ANTHROPIC_API_KEY=

ATHENA_PLAYWRIGHT_HEADLESS=true

ATHENA_VECTOR_DATABASE_URL=
